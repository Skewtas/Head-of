{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/automations/daily",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/newsletter/process-scheduled",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/dashboard/email-summary",
      "schedule": "0 6 * * 1-5"
    }
  ],
  "rewrites": [
    { "source": "/auth/callback", "destination": "/api/auth/callback" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
